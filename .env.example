AI_API_KEY=""
AI_BASE_URL="https://openrouter.ai/api/v1"
DATABASE_URL="sqlite://data/buoya.db"

# Telegram connector bot token (from @BotFather). Leave blank to disable.
# Also set [connectors.telegram] enabled=true + chat_id in config to activate.
TELEGRAM_BOT_TOKEN=""

# Bearer token required to call the MCP endpoint (/mcp). Clients must send
# `Authorization: Bearer <token>`. Leave blank for no auth (loopback only); set a
# strong value before exposing /mcp through a public tunnel for Claude.ai/ChatGPT.
MCP_AUTH_TOKEN=""
